{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM"],
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "noEmit": false,
    "types": ["bun"],
    "allowJs": false
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
